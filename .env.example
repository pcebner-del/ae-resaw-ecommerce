# --- Site ---
# Used to construct absolute URLs when the request origin is unavailable (e.g. webhook redirects).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Stripe ---
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Created by `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# or in the Stripe Dashboard under Developers > Webhooks.
STRIPE_WEBHOOK_SECRET=

# --- Shipping ---
# Provider: "shippo", "easypost", or "auto" (auto chooses by which key is present).
# Leave both keys empty to use the built-in mock estimator for local development.
SHIPPING_PROVIDER=auto
SHIPPING_ORIGIN_ZIP=85225
SHIPPO_API_KEY=
EASYPOST_API_KEY=

# --- Contact (Resend) ---
# Sign up at https://resend.com and verify your sending domain.
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@aeresaw.com
CONTACT_FROM_EMAIL=A&E Resaw <noreply@aeresaw.com>
